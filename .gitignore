# Directories to ignore
node_modules/
/build/
logs/
tmp/
out/
src/applications/vaos/docs/
src/site/tests/html/
mocha/results

# Files to ignore
._*
.cache
.config
.DS_Store
.env
npm-debug.log
*.log
*.swp 

config/config.proxy.js

.babelcache
jsconfig.json
typings.json
typings/
coverage
/cypress
/playwright-report
/blob-report
playwright-durations.json
playwright-shards.json
.nyc_output
.yalc
yalc.lock
package-lock.json
temp
dump.rdb

# Ignore user's editor/IDE prefs
.vscode/
*.code-workspace
.idea/
.nova/
.swp
.swo
all-links.csv
.tern-port
*.iml
.ignore
.tool-versions
.cursorrules
.claude/settings.local.json

# Generated files from OpenAPI specs
src/applications/benefits-optimization-aquia/**/generated/

# Track shared IDE config
!.vscode/extensions.json
!.vscode/launch.json

# Ignore custom generated Cypress-TestRail configs
config/my-cypress-testrail.json
config/my-cypress-testrail.config.js
script/cypress-testrail-helper/my-config.json

# Ignore mochawesome report directory
mochawesome-report/
test-results/
